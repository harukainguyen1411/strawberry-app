#!/bin/sh
# Stub for age — should NEVER be invoked by _lib.sh (which must use tools/decrypt.sh).
# Any invocation means the lib violated Rule 6.
# Records invocation in AGE_STUB_LOG so tests can assert it was never called.

LOG="${AGE_STUB_LOG:-/tmp/age-stub.log}"
printf 'age-stub: ILLEGAL INVOCATION args=%s\n' "$*" >> "${LOG}"
printf 'age-stub: _lib.sh called raw age — Rule 6 violation\n' >&2
exit 1
