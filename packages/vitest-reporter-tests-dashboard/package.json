{
  "name": "@strawberry/vitest-reporter-tests-dashboard",
  "version": "1.0.0",
  "description": "Vitest custom reporter that emits test-results.json / test-run-history.json for the Strawberry tests dashboard",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vitest": "^4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ajv": "^8.17.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
