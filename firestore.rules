rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — per-user profile document
    match /users/{uid} {
      // Only the authenticated owner may read their own profile.
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create: must be the owner, must include baseCurrency (USD or EUR),
      // and must contain ONLY the allowed keys — no extra fields like isAdmin.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'baseCurrency'])
        && request.resource.data.baseCurrency in ['USD', 'EUR'];

      // Update: owner only; updated fields must be a subset of allowed keys;
      // baseCurrency (if present in the write) must remain a valid enum value.
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'baseCurrency'])
        && (!('baseCurrency' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.baseCurrency in ['USD', 'EUR']);

      // Users may not delete their own profile document.
      allow delete: if false;

      // Subcollections (positions, trades) — owner read/write; trades are immutable.
      match /positions/{ticker} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /trades/{tradeId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // Trades are append-only — create allowed, update/delete blocked.
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
