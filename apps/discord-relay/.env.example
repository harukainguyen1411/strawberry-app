# Discord bot token (required)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Path to channel-map.json (optional, defaults to ./channel-map.json)
# Run scripts/setup-discord-channels.sh to generate channel IDs and populate this file.
CHANNEL_MAP_PATH=./channel-map.json

# DEPRECATED: Single-channel mode. Use channel-map.json instead.
# TRIAGE_DISCORD_CHANNEL_ID=your-channel-id

# Gemini API key (required)
GEMINI_API_KEY=your-gemini-api-key

# GitHub token with repo scope (required)
GITHUB_TOKEN=your-github-token

# Optional overrides
# TRIAGE_TARGET_SUBTREE=apps/myapps
# TRIAGE_TARGET_LABEL=myapps
# TRIAGE_CONTEXT_REFRESH_HOURS=6
# TRIAGE_DAILY_QUOTA=1000
# LOG_PATH=/path/to/triage.log
# PORT=8080

# Webhook secret for GitHub Actions -> Discord relay notifications (required for feedback loop)
# DISCORD_RELAY_WEBHOOK_SECRET=your-shared-hmac-secret

# Discord user ID of the approver (required for reaction-based PR merge/close)
# APPROVER_DISCORD_ID=your-discord-user-id
