rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Bee: Haruka-only read/write for upload inputs.
    // Portal uploads to: bee-temp/{uid}/{timestamp}/input.docx
    // Worker writes (result.docx, transcript.md) use Admin SDK — bypass rules.
    match /bee-temp/{uid}/{ts}/{file} {
      allow read:  if request.auth != null
                   && request.auth.uid == uid
                   && request.auth.uid == "0DJzc86i5MP74jAwwT4YjvbcAub2"; // gitleaks:allow
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.auth.uid == "0DJzc86i5MP74jAwwT4YjvbcAub2" // gitleaks:allow
                   && file == "input.docx"
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType == "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
    }
  }
}
