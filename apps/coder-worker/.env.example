# Copy this to .env and fill in real values.
# .env is gitignored — never commit real tokens.

# Required
GITHUB_TOKEN=ghp_your_github_triage_pat_here

# Optional — defaults shown
TRIAGE_TARGET_REPO=Duongntd/myapps
POLL_INTERVAL_SECONDS=60
MAX_CONCURRENT_JOBS=1
CLAUDE_MAX_TURNS=25

# Path to the coder agent system prompt
# Default resolves to .github/coder-agent/system.md from repo root
# SYSTEM_PROMPT_PATH=

# Path to shared runlock file (shared with Bee worker)
# Default: %USERPROFILE%\.claude-runlock\claude.lock
# RUNLOCK_PATH=

# Per-invocation Claude audit log directory (outside repo tree, invisible to Claude)
# Default: %USERPROFILE%\coder-worker\var\logs\
# AUDIT_LOG_DIR=

# Optional worker log file path (in addition to stdout)
# LOG_PATH=logs\coder-worker.jsonl

# Reviewer auto-assign — comma-separated GitHub usernames
# Config file (config/reviewers.yaml) takes precedence when both set.
CODER_WORKER_DEFAULT_REVIEWERS=Duongntd
